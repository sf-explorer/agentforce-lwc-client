<?xml version="1.0" encoding="UTF-8" ?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>67.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Agentforce Chat</masterLabel>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__UtilityBar</target>
    </targets>
    <targetConfigs>
        <targetConfig
      targets="lightning__AppPage,lightning__HomePage,lightning__RecordPage,lightning__UtilityBar"
    >
            <property
        name="agentApiName"
        type="String"
        label="Agent API Name"
        required="false"
      />
            <property name="title" type="String" label="Title" />
            <property
        name="placeholder"
        type="String"
        label="Input Placeholder"
      />
            <property
        name="welcomeMessage"
        type="String"
        label="Welcome Message"
      />
            <property
        name="samplePrompts"
        type="String"
        label="Sample Prompts"
        description="Use newline, semicolon, or pipe separators."
      />
            <property
        name="skillsJson"
        type="String"
        label="Skills JSON"
        description="Optional JSON array with label and content__c fields for @ mention resolution."
      />
            <property
        name="showHeader"
        type="Boolean"
        label="Show Header"
        default="true"
      />
            <property
        name="showAvatar"
        type="Boolean"
        label="Show Avatars"
        default="true"
      />
            <property
        name="maxHistory"
        type="Integer"
        label="Max History"
        default="30"
      />
            <property
        name="minHeight"
        type="String"
        label="Min Height"
        default="auto"
      />
            <property
        name="maxHeight"
        type="String"
        label="Max Height"
        default="none"
      />
            <property
        name="disabled"
        type="Boolean"
        label="Disable Input"
        default="false"
      />
            <property
        name="voiceInputEnabled"
        type="Boolean"
        label="Enable Voice Input"
        default="false"
      />
            <property
        name="voiceLanguage"
        type="String"
        label="Voice Input Language"
        default="en-US"
      />
            <property
        name="markdownEnabled"
        type="Boolean"
        label="Enable Markdown"
        default="true"
      />
            <property
        name="markdownRenderer"
        type="String"
        label="Markdown Renderer"
        description="Choose custom renderer or lightning-formatted-rich-text."
        default="custom"
        datasource="custom,richText"
      />
            <property
        name="showCitations"
        type="Boolean"
        label="Show Citations"
        default="true"
      />
            <property
        name="mode"
        type="String"
        label="Session Mode"
        default="uncontrolled"
      />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
